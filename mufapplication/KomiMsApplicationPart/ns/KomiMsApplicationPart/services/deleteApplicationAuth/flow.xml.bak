<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE" FORM="TRY">
  <COMMENT></COMMENT>

  <!-- nodes -->

<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT>validasi partnerReferenceNo</COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="%partnerReferenceNo% == null || %partnerReferenceNo% == &#34;&#34;" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$parent" SIGNAL="FAILURE" FAILURE-MESSAGE="MISSING_PARENT_REFERENCE_NO">
  <COMMENT>missing parent reference no</COMMENT>
</EXIT>
</SEQUENCE>
</BRANCH>

<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="%authSeq% == &#34;&#34; || %authSeq% == null" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$parent" SIGNAL="FAILURE" FAILURE-MESSAGE="MISSING_MANDATORY_FIELD_AUTHSEQ">
  <COMMENT>missing mandatory field</COMMENT>
</EXIT>
</SEQUENCE>

<SEQUENCE NAME="%authSeq% &lt;= 0" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$parent" SIGNAL="FAILURE" FAILURE-MESSAGE="INVALID_MANDATORY_FIELD_AUTHSEQ">
  <COMMENT>invalid mandatory field</COMMENT>
</EXIT>
</SEQUENCE>

