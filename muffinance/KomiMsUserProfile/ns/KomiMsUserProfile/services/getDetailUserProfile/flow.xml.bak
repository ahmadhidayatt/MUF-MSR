  <COMMENT>Invalid mandatory field {nik}</COMMENT>
</EXIT>
</SEQUENCE>

<SEQUENCE NAME="%/nik% == null" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

