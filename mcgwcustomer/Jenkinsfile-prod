pipeline {
    agent any
    environment {
        NEXUS_BASE_URL = 'svr-ocp-nex-d01.muf.co.id:5000' //url nexus
        NEXUS_PROJECT = 'mcgw'
        NEXUS_SUB_PROJECT = 'mcgwprod'
        PROJECT_NAME = 'esb' //NAMESPACENAME ocp
        OCP_API = 'https://api.ocpdc.muf.co.id:6443'
        OCP_API_DRC = 'https://api.ocpdrc.muf.co.id:6443'
        IMAGE_PROJECT = "esb"
        IMAGE_NAME = "mcgwcustomer"
        IMAGE_ENV = "prod"
        IMAGE_ENV_DRC = "proddrc"
        ESB_VERSION="10.15"
        APP_NAME = "mcgwcustomer"
        KUBECONFIG = "/var/lib/jenkins/.kube/config-${APP_NAME}" // Set kubeconfig globally
        NEXUS_ENV = 'msr'
        IMAGE_ENVSUBST_NAME = "alpine-envsubst"
        IMAGE_ENVSUBST_VERSION = "v1.0"
        SECRET_REF_NAME = "mcgwcustomer-secret"
    }
    stages {
        stage('Source Code Checkout') {
            steps {
                script {
                    checkout([$class: 'GitSCM',
                              userRemoteConfigs: [[url: 'https://bitbucket.muf.co.id/scm/ip/mcgwcustomer.git', credentialsId: 'id-bitbucket']],
                              branches: [[name: '*/master']]
                    ])
                }
            }
        }
        stage('Podman Build') {
            steps {
                script{
                    sh "podman build --tls-verify=false -t ${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT}/${IMAGE_NAME}:${ESB_VERSION}-${BUILD_NUMBER} -f Dockerfile-prod ."
                }
            }
        }
        stage('Podman Push'){
            steps{
                withCredentials([usernamePassword(credentialsId: 'nexus-credentials', passwordVariable: 'password', usernameVariable: 'username')]) {
                    sh "podman login --tls-verify=false ${NEXUS_BASE_URL} -u ${username} -p ${password}"
                    sh "podman push --tls-verify=false ${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT}/${IMAGE_NAME}:${ESB_VERSION}-${BUILD_NUMBER}"
                }
            }
        }
        stage('Cleanup Podman Image') {
            steps {
                script {
                    sh "podman rmi -f ${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT}/${IMAGE_NAME}:${ESB_VERSION}-${BUILD_NUMBER}"
                }
            }
        }
        stage('OCP Deployment DC'){
            steps{
                echo 'Login to OCP'
                withCredentials([usernamePassword(credentialsId: 'custodian-ocp-credential', passwordVariable: 'password', usernameVariable: 'username')]) {
                    sh "oc login ${OCP_API} -u ${username} -p ${password} --insecure-skip-tls-verify"

                }
                sh "oc project ${PROJECT_NAME}"

                echo 'Deploy OCP - helm install or upgrade'
                script {
                    // Check if any pod related to the release exists
                    def podCheckStatus = sh(script: "oc get pods -l app.kubernetes.io/name=${IMAGE_NAME} -n ${IMAGE_PROJECT} --ignore-not-found=true", returnStatus: true)
                    def podCheckOutput = sh(script: "oc get pods -l app.kubernetes.io/name=${IMAGE_NAME} -n ${IMAGE_PROJECT} --ignore-not-found=true", returnStdout: true).trim()
                    echo "Pod Check Status: ${podCheckStatus}"
                    echo "Pod Check Output: ${podCheckOutput}"
                    if (podCheckOutput.contains("NAME")) {
                        // Pods exist, proceed with helm upgrade
                        echo 'Pods exist, running helm upgrade'
                        sh '''
                            helm upgrade --install ${IMAGE_NAME} ./helmchart \
                                --set env=${IMAGE_ENV} \
                                --set image.repository=${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT} \
                                --set image.tag=${ESB_VERSION}-${BUILD_NUMBER} \
                                --set imageEnvSubst.repository=${NEXUS_BASE_URL}/${NEXUS_ENV} \
                                --set imageEnvSubst.name=${IMAGE_ENVSUBST_NAME} \
                                --set imageEnvSubst.tag=${IMAGE_ENVSUBST_VERSION} \
                                --set secret.ref=${SECRET_REF_NAME} \
                                --namespace ${IMAGE_PROJECT}
                        '''
                    } else {
                        // Pods do not exist, proceed with helm install
                        echo 'No pods found, running helm install'
                        sh '''
                            helm install ${IMAGE_NAME} ./helmchart \
                                --set env=${IMAGE_ENV} \
                                --set image.repository=${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT} \
                                --set image.tag=${ESB_VERSION}-${BUILD_NUMBER} \
                                --set imageEnvSubst.repository=${NEXUS_BASE_URL}/${NEXUS_ENV} \
                                --set imageEnvSubst.name=${IMAGE_ENVSUBST_NAME} \
                                --set imageEnvSubst.tag=${IMAGE_ENVSUBST_VERSION} \
                                --set secret.ref=${SECRET_REF_NAME} \
                                --namespace ${IMAGE_PROJECT}
                        '''
                    }
                }
            }
        }

        stage('OCP Deployment DRC'){
            steps{
                echo 'Login to OCP'
                withCredentials([usernamePassword(credentialsId: 'custodian-ocp-credential', passwordVariable: 'password', usernameVariable: 'username')]) {
                    sh "oc login ${OCP_API_DRC} -u ${username} -p ${password} --insecure-skip-tls-verify"

                }
                sh "oc project ${PROJECT_NAME}"

                echo 'Deploy OCP - helm install or upgrade'
                script {
                    // Check if any pod related to the release exists
                    def podCheckStatus = sh(script: "oc get pods -l app.kubernetes.io/name=${IMAGE_NAME} -n ${IMAGE_PROJECT} --ignore-not-found=true", returnStatus: true)
                    def podCheckOutput = sh(script: "oc get pods -l app.kubernetes.io/name=${IMAGE_NAME} -n ${IMAGE_PROJECT} --ignore-not-found=true", returnStdout: true).trim()
                    echo "Pod Check Status: ${podCheckStatus}"
                    echo "Pod Check Output: ${podCheckOutput}"
                    if (podCheckOutput.contains("NAME")) {
                        // Pods exist, proceed with helm upgrade
                        echo 'Pods exist, running helm upgrade'
                        sh '''
                            helm upgrade --install ${IMAGE_NAME} ./helmchart \
                                --set env=${IMAGE_ENV_DRC} \
                                --set image.repository=${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT} \
                                --set image.tag=${ESB_VERSION}-${BUILD_NUMBER} \
                                --set imageEnvSubst.repository=${NEXUS_BASE_URL}/${NEXUS_ENV} \
                                --set imageEnvSubst.name=${IMAGE_ENVSUBST_NAME} \
                                --set imageEnvSubst.tag=${IMAGE_ENVSUBST_VERSION} \
                                --set secret.ref=${SECRET_REF_NAME} \
                                --namespace ${IMAGE_PROJECT}
                        '''
                    } else {
                        // Pods do not exist, proceed with helm install
                        echo 'No pods found, running helm install'
                        sh '''
                            helm install ${IMAGE_NAME} ./helmchart \
                                --set env=${IMAGE_ENV_DRC} \
                                --set image.repository=${NEXUS_BASE_URL}/${NEXUS_PROJECT}/${NEXUS_SUB_PROJECT} \
                                --set image.tag=${ESB_VERSION}-${BUILD_NUMBER} \
                                --set imageEnvSubst.repository=${NEXUS_BASE_URL}/${NEXUS_ENV} \
                                --set imageEnvSubst.name=${IMAGE_ENVSUBST_NAME} \
                                --set imageEnvSubst.tag=${IMAGE_ENVSUBST_VERSION} \
                                --set secret.ref=${SECRET_REF_NAME} \
                                --namespace ${IMAGE_PROJECT}
                        '''
                    }
                }
            }
        }
        
    }
}
